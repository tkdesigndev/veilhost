---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Buy Now | The Veilhost Trilogy">
	<section class="buy-hero">
		<div class="page-shell">
			<p class="kicker">The Creatures Lurk</p>
			<h1>Buy Now</h1>
			<p class="release-note">Available on Kindle and in Paperback 31st July</p>
		</div>
	</section>

	<section class="buy-options page-shell" aria-label="Buying options">
		<article class="buy-card">
			<div class="kindle-logo" aria-label="Kindle logo">kindle</div>
			<h2>Pre-order for Kindle</h2>
			<a href="https://www.amazon.co.uk/dp/B0H9BNDGXD?spcref=PUBLISHED_PREORDER_LIVE" target="_blank"><p class="availability">Pre-order now</p></a>
		</article>

		<article class="buy-card">
			<div class="amazon-logo" aria-label="Amazon logo">amazon</div>
			<h2>Buy the paperback on Amazon</h2>
			<p class="availability">Available soon</p>
		</article>
	</section>
</Layout>

<style>
	.buy-hero {
		padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 5vw, 3.5rem);
		background: linear-gradient(180deg, rgba(8, 7, 5, 0.96), rgba(8, 7, 5, 0.78));
		color: var(--color-white);
		text-align: center;
	}

	.kicker {
		margin-bottom: 1.2rem;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1 {
		margin-bottom: 1rem;
		font-size: clamp(4.5rem, 12vw, 9rem);
	}

	.release-note {
		display: inline-block;
		margin-bottom: 0;
		border-block: 2px solid currentColor;
		padding: 0.4rem 0;
		font-size: clamp(1.1rem, 3vw, 1.85rem);
		font-weight: 900;
		line-height: 1.1;
		text-transform: uppercase;
	}

	.buy-options {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(1rem, 4vw, 2rem);
		padding: clamp(3rem, 8vw, 6rem) 0;
	}

	.buy-card {
		display: grid;
		align-content: start;
		gap: 1rem;
		min-height: 320px;
		border: 3px solid var(--color-black);
		background: var(--color-white);
		padding: clamp(1.4rem, 4vw, 2.5rem);
		box-shadow: 12px 12px 0 var(--color-black);
	}

	.kindle-logo,
	.amazon-logo {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		min-height: 3rem;
		color: var(--color-black);
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 900;
		letter-spacing: -0.06em;
		line-height: 1;
		text-transform: lowercase;
	}

	.kindle-logo {
		font-family: Georgia, "Times New Roman", serif;
		font-weight: 700;
	}

	.amazon-logo {
		position: relative;
		font-family: Arial, Helvetica, sans-serif;
	}

	.amazon-logo::after {
		content: "";
		position: absolute;
		left: 1.7rem;
		right: 0.3rem;
		bottom: -0.35rem;
		height: 0.45rem;
		border-bottom: 4px solid var(--color-ember);
		border-radius: 50%;
		transform: rotate(-4deg);
	}

	h2 {
		margin: 0;
		font-size: clamp(2.4rem, 5vw, 4.8rem);
	}

	.availability {
		width: fit-content;
		margin: 0;
		background: var(--color-black);
		padding: 0.5rem 0.75rem;
		color: var(--color-white);
		font-size: 0.9rem;
		font-weight: 900;
		line-height: 1;
		text-transform: uppercase;
	}

	@media (max-width: 760px) {
		.buy-options {
			grid-template-columns: 1fr;
		}
	}
</style>
