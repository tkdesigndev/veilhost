---
import { Font } from "astro:assets";
import logo from "../assets/tvh-logo.png";

interface Props {
	title?: string;
}

const { title = "The Veilhost Trilogy" } = Astro.props;
const path = Astro.url.pathname;

const links = [
	{ href: "/", label: "Home" },
	{ href: "/about/", label: "About the author" },
	{ href: "/chapters/", label: "Read chapters" },
	{ href: "#buy-now", label: "Buy now" },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<Font cssVariable="--font-rusty-attack" preload />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="logo-link" href="/" aria-label="The Veilhost Trilogy home">
				<img src={logo.src} alt="The Veilhost Trilogy" class="site-logo" />
			</a>
			<nav class="site-nav" aria-label="Main navigation">
				{
					links.map((link) => (
						<a
							href={link.href}
							class:list={[
								"nav-link",
								link.href !== "#buy-now" && path === link.href ? "is-active" : "",
							]}
						>
							{link.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="site-footer-inner page-shell">
				<p>© Topher Knowles, 2026</p>
				<a
					class="instagram-link"
					href="https://www.instagram.com/tknowlesauthor"
					target="_blank"
					rel="noreferrer"
				>
					<svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
						<rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
						<circle cx="12" cy="12" r="4"></circle>
						<circle cx="17.5" cy="6.5" r="1"></circle>
					</svg>
					<span>Follow on Instagram</span>
				</a>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--color-ember: #d98327;
		--color-black: #080705;
		--color-white: #fffaf2;
		--color-ink: #16110c;
		--space-page: clamp(1rem, 4vw, 3rem);
		--content-width: 1120px;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: var(--color-ember);
		color: var(--color-black);
		font-family: Arial, Helvetica, sans-serif;
		line-height: 1.6;
		text-rendering: optimizeLegibility;
	}

	body::before {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -2;
		background:
			radial-gradient(circle at 10% 0%, rgba(255, 250, 242, 0.4), transparent 28rem),
			linear-gradient(180deg, rgba(217, 131, 39, 0.95), rgba(217, 131, 39, 0.78));
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
	}

	h1,
	h2,
	h3,
	.display-font {
		font-family: var(--font-rusty-attack), Arial, sans-serif;
		font-weight: 400;
		line-height: 0.96;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	button,
	input {
		font: inherit;
	}

	.site-header {
		position: relative;
		z-index: 10;
		display: grid;
		place-items: center;
		gap: 0.75rem;
		padding: 1rem var(--space-page) 0.5rem;
		background: #000;
		color: var(--color-white);
	}

	.logo-link {
		display: inline-flex;
		justify-content: center;
		width: min(340px, 72vw);
		transition: transform 180ms ease;
	}

	.logo-link:hover {
		transform: translateY(-2px);
	}

	.site-logo {
		max-width: 130px;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.25rem 0 0.75rem;
	}

	.nav-link {
		border: 1px solid rgba(255, 250, 242, 0.42);
		background: rgba(255, 250, 242, 0.08);
		padding: 0.52rem 0.82rem;
		color: var(--color-white);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.nav-link:hover,
	.nav-link.is-active {
		background: var(--color-white);
		color: var(--color-black);
		transform: translateY(-1px);
	}

	main {
		min-height: calc(100vh - 190px);
	}

	.site-footer {
		background: var(--color-black);
		padding: 1.25rem 0;
		color: var(--color-white);
	}

	.site-footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.site-footer p {
		margin-bottom: 0;
		font-size: 0.9rem;
		font-weight: 800;
	}

	.instagram-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--color-white);
		font-size: 0.9rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.instagram-link:hover {
		color: var(--color-ember);
		transform: translateY(-1px);
	}

	.instagram-link svg {
		width: 1.15rem;
		height: 1.15rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
	}

	.page-shell {
		width: min(var(--content-width), calc(100% - (var(--space-page) * 2)));
		margin: 0 auto;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.9rem;
		border: 2px solid var(--color-black);
		background: var(--color-black);
		padding: 0.75rem 1rem;
		color: var(--color-white);
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.btn:hover {
		background: var(--color-white);
		color: var(--color-black);
		box-shadow: 6px 6px 0 var(--color-black);
		transform: translate(-2px, -2px);
	}

	@media (max-width: 700px) {
		.site-header {
			padding-top: 0.75rem;
		}

		.site-nav {
			width: 100%;
		}

		.nav-link {
			flex: 1 1 42%;
			text-align: center;
		}

		.site-footer-inner {
			flex-direction: column;
			justify-content: center;
			text-align: center;
		}
	}
</style>
